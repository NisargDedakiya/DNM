# Production environment variables (placeholders; DO NOT commit secrets)
# PostgreSQL
POSTGRES_DB=nisarghunter
POSTGRES_USER=nhuser
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://nhuser:CHANGE_ME_TO_A_STRONG_PASSWORD@postgres:5432/nisarghunter

# Redis
REDIS_URL=redis://redis:6379/0

# App secrets
SECRET_KEY=CHANGE_ME_TO_A_SECRET
ANTHROPIC_API_KEY=

# Frontend
REACT_APP_API_BASE=https://your.domain.example/api
REACT_APP_WS_HOST=your.domain.example

# Misc
NODE_ENV=production
