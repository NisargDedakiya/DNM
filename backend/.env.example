# Application Configuration
APP_NAME=NisargHunterAI
APP_VERSION=1.0.0
DEBUG=true

# Security
SECRET_KEY=change_this_secret_key_in_production

# Database Configuration (uses asyncpg async driver)
DATABASE_URL=postgresql+asyncpg://nisarg:password@localhost/nisarghunter

# Redis Configuration
REDIS_URL=redis://localhost:6379

# External APIs
ANTHROPIC_API_KEY=your_anthropic_key_here
HACKERONE_USERNAME=your_hackerone_username
HACKERONE_API_TOKEN=your_hackerone_api_token
